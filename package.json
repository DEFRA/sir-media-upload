{
  "name": "sir-media-upload",
  "version": "0.1.0",
  "description": "Smart Incident Reporting media upload service",
  "main": "app/index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "build:css": "./bin/build-css.sh",
    "build:js": "./bin/build-js.sh",
    "build": "./bin/build.sh",
    "copy:static": "bin/copy-static.sh",
    "debug": "nodemon --inspect index.js",
    "watch:css": "nodemon -e scss -x 'npm run build:css'",
    "watch:nodejs": "nodemon --delay 1000ms --signal SIGTERM -r dotenv/config index.js",
    "dev": "concurrently 'npm:watch:css' 'npm:watch:nodejs'",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "unit-test": "jest --runInBand --verbose",
    "test": "npm run lint && npm run unit-test",
    "start-backend": "docker-compose -f docker/backend-services.yml up -d",
    "stop-backend": "docker-compose -f docker/backend-services.yml down"
  },
  "author": "",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@azure-rest/ai-content-safety": "^1.0.1",
    "@azure/core-auth": "^1.10.1",
    "@azure/service-bus": "^7.9.5",
    "@azure/storage-blob": "^12.31.0",
    "@hapi/catbox-redis": "^7.0.2",
    "@hapi/hapi": "21.4.3",
    "@hapi/inert": "^7.1.0",
    "@hapi/vision": "^7.0.3",
    "@hapi/yar": "11.0.3",
    "govuk-frontend": "^6.1.0",
    "hapi-pino": "^12.1.0",
    "heic-convert": "^2.1.0",
    "joi": "^18.0.2",
    "moment": "^2.30.1",
    "nunjucks": "^3.2.4",
    "sass": "^1.98.0",
    "sharp": "^0.34.5",
    "webpack-cli": "^7.0.2"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.0",
    "@hapi/catbox-memory": "^6.0.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "form-data": "^4.0.5",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "node-html-parser": "^7.1.0",
    "nodemon": "3.1.10",
    "standard": "^17.1.2"
  },
  "standard": {
    "globals": [
      "describe",
      "beforeEach",
      "expect",
      "it",
      "afterEach",
      "jest",
      "beforeAll",
      "afterAll"
    ],
    "ignore": [
      "**/public/build/js/"
    ]
  },
  "jest": {
    "collectCoverage": true,
    "coverageReporters": [
      "lcov",
      "text"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    },
    "coveragePathIgnorePatterns": [
      "__test-helpers__"
    ],
    "setupFiles": [
      "./.jest/test.env.js"
    ],
    "setupFilesAfterEnv": [
      "./.jest/setup.js"
    ],
    "testPathIgnorePatterns": [
      "__test-helpers__"
    ]
  }
}
